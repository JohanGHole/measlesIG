{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://smart.who.int/base/StructureDefinition-Epidemiologist.schema.json",
  "title": "Epidemiologist",
  "description": "",
  "type": "object",
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Epidemiologist",
      "description": "Resource type identifier for Epidemiologist logical model"
    },
    "@context": {
      "description": "JSON-LD context for this logical model with ValueSet vocabularies",
      "anyOf": [
        {
          "type": "string",
          "format": "uri",
          "description": "URI reference to external JSON-LD context"
        },
        {
          "type": "object",
          "description": "Inline JSON-LD context",
          "properties": {
            "@version": {
              "type": "number",
              "const": 1.1
            },
            "fhir": {
              "type": "string",
              "const": "http://hl7.org/fhir/"
            }
          },
          "additionalProperties": {
            "type": "string",
            "format": "uri"
          }
        },
        {
          "type": "array",
          "description": "Array of JSON-LD context objects/URIs",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "object"
              }
            ]
          }
        }
      ]
    },
    "@type": {
      "type": "string",
      "description": "JSON-LD type identifier for Epidemiologist logical model",
      "examples": [
        "LogicalModel-Epidemiologist"
      ]
    },
    "revisionStatus": {
      "oneOf": [
        {
          "type": "string",
          "description": "Code from ValueSet RevisionStatusVS (plain string)"
        },
        {
          "type": "object",
          "description": "Code from ValueSet RevisionStatusVS (JSON-LD structure)",
          "properties": {
            "@type": {
              "type": "string",
              "const": "http://smart.who.int/base/ValueSet-RevisionStatusVS.jsonld",
              "description": "JSON-LD type reference to ValueSet RevisionStatusVS"
            },
            "@id": {
              "type": "string",
              "format": "uri",
              "description": "Full IRI of the code from ValueSet RevisionStatusVS"
            }
          },
          "required": [
            "@type",
            "@id"
          ],
          "additionalProperties": false
        }
      ],
      "description": "Revision status"
    },
    "nationalPublicHealthMeasures": {
      "oneOf": [
        {
          "type": "string",
          "description": "Code from ValueSet IndividualPublicHealthMeasuresVS (plain string)"
        },
        {
          "type": "object",
          "description": "Code from ValueSet IndividualPublicHealthMeasuresVS (JSON-LD structure)",
          "properties": {
            "@type": {
              "type": "string",
              "const": "http://smart.who.int/base/ValueSet-IndividualPublicHealthMeasuresVS.jsonld",
              "description": "JSON-LD type reference to ValueSet IndividualPublicHealthMeasuresVS"
            },
            "@id": {
              "type": "string",
              "format": "uri",
              "description": "Full IRI of the code from ValueSet IndividualPublicHealthMeasuresVS"
            }
          },
          "required": [
            "@type",
            "@id"
          ],
          "additionalProperties": false
        }
      ],
      "description": "National Public health measures"
    },
    "transmission": {
      "oneOf": [
        {
          "type": "string",
          "description": "Code from ValueSet TransmissionVS (plain string)"
        },
        {
          "type": "object",
          "description": "Code from ValueSet TransmissionVS (JSON-LD structure)",
          "properties": {
            "@type": {
              "type": "string",
              "const": "http://smart.who.int/base/ValueSet-TransmissionVS.jsonld",
              "description": "JSON-LD type reference to ValueSet TransmissionVS"
            },
            "@id": {
              "type": "string",
              "format": "uri",
              "description": "Full IRI of the code from ValueSet TransmissionVS"
            }
          },
          "required": [
            "@type",
            "@id"
          ],
          "additionalProperties": false
        }
      ],
      "description": "Transmission"
    }
  },
  "required": [
    "resourceType",
    "revisionStatus"
  ],
  "resourceDefinition": "http://example.org/StructureDefinition/Epidemiologist",
  "fhir:parent": "http://hl7.org/fhir/StructureDefinition/Base",
  "jsonld:valuesets": [
    "IndividualPublicHealthMeasuresVS",
    "TransmissionVS",
    "RevisionStatusVS"
  ],
  "jsonld:contextTemplate": {
    "@version": 1.1,
    "fhir": "http://hl7.org/fhir/",
    "IndividualPublicHealthMeasuresVS": "http://smart.who.int/base/ValueSet-IndividualPublicHealthMeasuresVS.jsonld",
    "TransmissionVS": "http://smart.who.int/base/ValueSet-TransmissionVS.jsonld",
    "RevisionStatusVS": "http://smart.who.int/base/ValueSet-RevisionStatusVS.jsonld"
  }
}