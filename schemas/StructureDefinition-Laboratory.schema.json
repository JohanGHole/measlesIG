      "description": "Date sample delivered to lab"
    },
    "dateSampleTested": {
      "type": "string",
      "format": "date",
      "description": "Date sample tested"
    },
    "dateOfTheResult": {
      "type": "string",
      "format": "date",
      "description": "Date of the result"
    },
    "laboratoryName": {
      "oneOf": [
        {
          "type": "string",
          "description": "Code from ValueSet LabNameVS (plain string)"
        },
        {
          "type": "object",
          "description": "Code from ValueSet LabNameVS (JSON-LD structure)",
          "properties": {
            "@type": {
              "type": "string",
              "const": "http://smart.who.int/base/ValueSet-LabNameVS.jsonld",
              "description": "JSON-LD type reference to ValueSet LabNameVS"
            },
            "@id": {
              "type": "string",
              "format": "uri",
              "description": "Full IRI of the code from ValueSet LabNameVS"
            }
          },
          "required": [
            "@type",
            "@id"
          ],
          "additionalProperties": false
        }
